{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/cards/**",
              "components/core/**",
              "components/data/**",
              "components/navigation/**",
              "ui_kits/portfolio/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Plus Jakarta Sans))/i]",
        "message": "Font not provided by the design system. Available: Plus Jakarta Sans."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|onClick|type|disabled|className|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, onClick, type, disabled, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit)$/]",
        "message": "<Button> type must be one of 'button' | 'submit'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DashboardVisitorCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|delta|deltaTone|key|ref|className|style|children)$/]",
        "message": "<DashboardVisitorCard> doesn't accept that prop. Declared props: label, value, delta, deltaTone."
      },
      {
        "selector": "JSXOpeningElement[name.name='DashboardVisitorCard'] > JSXAttribute[name.name='deltaTone'] > Literal[value!=/^(?:good|bad|neutral)$/]",
        "message": "<DashboardVisitorCard> deltaTone must be one of 'good' | 'bad' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DonutSegment'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|percent|color|icon|iconSet|key|ref|className|style|children)$/]",
        "message": "<DonutSegment> doesn't accept that prop. Declared props: label, percent, color, icon, iconSet."
      },
      {
        "selector": "JSXOpeningElement[name.name='DonutSegment'] > JSXAttribute[name.name='iconSet'] > Literal[value!=/^(?:lucide|brand)$/]",
        "message": "<DonutSegment> iconSet must be one of 'lucide' | 'brand'."
      },
      {
        "selector": "JSXOpeningElement[name.name='HeaderLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:href|label|key|ref|className|style|children)$/]",
        "message": "<HeaderLink> doesn't accept that prop. Declared props: href, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|set|size|className|style|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, set, size, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute[name.name='set'] > Literal[value!=/^(?:lucide|brand)$/]",
        "message": "<Icon> set must be one of 'lucide' | 'brand'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|delta|deltaTone|helpText|key|ref|className|style|children)$/]",
        "message": "<MetricCard> doesn't accept that prop. Declared props: label, value, delta, deltaTone, helpText."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricCard'] > JSXAttribute[name.name='deltaTone'] > Literal[value!=/^(?:good|bad|neutral)$/]",
        "message": "<MetricCard> deltaTone must be one of 'good' | 'bad' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TimelineImage'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|alt|key|ref|className|style|children)$/]",
        "message": "<TimelineImage> doesn't accept that prop. Declared props: src, alt."
      },
      {
        "selector": "JSXOpeningElement[name.name='SocialLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|url|label|key|ref|className|style|children)$/]",
        "message": "<SocialLink> doesn't accept that prop. Declared props: icon, url, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatBarRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|iconSet|label|percent|color|key|ref|className|style|children)$/]",
        "message": "<StatBarRow> doesn't accept that prop. Declared props: icon, iconSet, label, percent, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatBarRow'] > JSXAttribute[name.name='iconSet'] > Literal[value!=/^(?:lucide|brand)$/]",
        "message": "<StatBarRow> iconSet must be one of 'lucide' | 'brand'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TechBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|key|ref|className|style|children)$/]",
        "message": "<TechBadge> doesn't accept that prop. Declared props: label."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextType'] > JSXAttribute > JSXIdentifier[name!=/^(?:text|typingSpeed|initialDelay|pauseDuration|deletingSpeed|loop|showCursor|cursorCharacter|className|style|key|ref|className|style|children)$/]",
        "message": "<TextType> doesn't accept that prop. Declared props: text, typingSpeed, initialDelay, pauseDuration, deletingSpeed, loop, showCursor, cursorCharacter, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TrafficLineChartSeries'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|color|values|key|ref|className|style|children)$/]",
        "message": "<TrafficLineChartSeries> doesn't accept that prop. Declared props: label, color, values."
      },
      {
        "selector": "JSXOpeningElement[name.name='WorkCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:href|onClick|title|logo|iconSrc|subtitle|bgColor|height|key|ref|className|style|children)$/]",
        "message": "<WorkCard> doesn't accept that prop. Declared props: href, onClick, title, logo, iconSrc, subtitle, bgColor, height."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
